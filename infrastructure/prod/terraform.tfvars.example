vpc_id               = "vpc-075b3102672a9af26"
private_subnet_ids   = ["subnet-048004a221680c742", "subnet-015e73eb696f8577c"]
public_subnet_ids    = ["subnet-XXXXXXXXXXXXXXXXX", "subnet-YYYYYYYYYYYYYYYYY"]
allowed_cidr_blocks  = ["172.31.0.0/16"]
db_password          = "CHANGE_ME_PROD_PASSWORD"
s3_bucket_name       = "prod-omnisolve-documents"
aws_region           = "us-east-1"

# HTTPS Configuration
# Set to true to enable HTTPS with Application Load Balancer
enable_https = true

# SSL Certificate ARN from AWS Certificate Manager (ACM)
# To create a certificate:
# 1. Go to AWS Certificate Manager in us-east-1
# 2. Request a public certificate for your domain (e.g., api.yourdomain.com)
# 3. Validate domain ownership (DNS or email)
# 4. Copy the certificate ARN here
ssl_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID"

